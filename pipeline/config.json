{
  "training": {
    "data_path": "./Training_data",
    "model_path": "./model/threat_detector.joblib",
    "test_size": 0.2,
    "random_state": 42,
    "feature_names": {
      "include_rule_names": true,
      "csv_paths": [
        "./Qradar_rule/qradar_customrules.csv",
        "./Qradar_rule/qradar_BBrules.csv"
      ]
    },
    "grid_search": {
      "enabled": true,
      "scoring": "roc_auc",
      "cv": 3,
      "verbose": 1,
       "param_grid": {
        "n_estimators": [300, 400, 500, 600, 700, 800, 900, 1000],
        "max_depth": [8, 12, 16, 20, null],
        "max_features": ["sqrt", "log2"],
        "min_samples_split": [10, 20, 30, 40, 50],
        "min_samples_leaf": [10, 15, 20],
        "class_weight": ["none", "balanced", "balanced_subsample"],
        "min_impurity_decrease": [0.0, 0.0001, 0.001, 0.01],
        "ccp_alpha": [0.0, 0.0001, 0.001, 0.01],
        "criterion": ["gini", "entropy"]
      }
    },
    "model_params": {
      "n_estimators": 200,
      "class_weight": "balanced_subsample",
      "max_features": "sqrt",
      "random_state": 42,
      "n_jobs": -1
    }
  },
  "detection": {
    "qradar_config": {
      "host": "192.168.153.123",
      "token": "677f60e2-3d58-4275-a1f0-c13d1975fdbe",
      "version": "20.0",
      "verify_ssl": false,
      "query_30min": "SELECT \"sysmon_hostname\" AS 'sysmon_hostname (custom)', \"creEventList\" AS 'Custom Rule', DATEFORMAT(MIN(\"deviceTime\"), 'MMM dd, yyyy, h:mm:ss a') AS 'Log Source Time (Minimum)', COUNT(*) AS 'Count' FROM events WHERE (\"Sysmon_hostname\" != NULL)GROUP BY \"sysmon_hostname\", \"creEventList\" ORDER BY \"Count\" DESC START '{start_time}' STOP '{end_time}'",
      "timeout": 300
    },
    "mongodb_config": {
      "connection_string": "mongodb://localhost:27017/",
      "database": "qradar_ml",
      "collection": "detection_data",
      "batch_size": 1000
    },
    "retention_days": 7,
    "alert_threshold": 0,
    "window_size_minutes": 30,
    "max_detection_age_hours": 24,
    "feature_names": {
      "include_rule_names": true,
      "csv_paths": [
        "./Qradar_rule/qradar_customrules.csv",
        "./Qradar_rule/qradar_BBrules.csv"
      ]
    },
    "shap": {
      "frequent_path_mining": {
        "enabled": false,
        "max_trees": 50,
        "max_depth": null,
        "itemset_sizes": [2],
        "top_k": 20,
        "min_support": 0.05
      }
    }
  },
  "rule_manager": {
    "mode": "file",
    "api_config": {
      "host": "192.168.153.123",
      "token": "677f60e2-3d58-4275-a1f0-c13d1975fdbe",
      "version": "20.0",
      "verify_ssl": false
    },
    "auto_refresh": true,
    "cache_duration_hours": 24
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file_prefix": "pipeline",
    "max_log_size_mb": 100,
    "backup_count": 5
  },
  "paths": {
    "training_data": "./Training_data",
    "model_output": "./model",
    "logs": "./running_log",
    "config": "./pipeline/config.json"
  }
}

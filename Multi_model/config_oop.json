{
  "description": "OOP Pipeline Configuration Example",
  "version": "1.0",
  
  "training": {
    "model_path": "./model/threat_detector.joblib",
    "test_size": 0.2,
    "random_state": 42,
    "grid_search": {
      "enabled": false,
      "scoring": "roc_auc",
      "cv": 3,
      "verbose": 1,
      "param_grid": {
        "n_estimators": [100, 200],
        "max_depth": [null, 10, 20],
        "max_features": ["sqrt", "log2"],
        "min_samples_split": [2, 5],
        "class_weight": ["balanced_subsample"]
      }
    }
  },
  
  "detection": {
    "threshold": 0.5,
    "time_window_minutes": 30,
    "alert_enabled": true
  },
  
  "data_sources": {
    "training_data_path": "./Training_data/normal",
    "attack_data_path": "./Training_data/attack",
    "mongodb_enabled": true
  },
  
  "rule_manager": {
    "mode": "file",
    "rule_file_path": "Qradar_rule/production_rules.txt",
    "uat_rule_file_path": "Qradar_rule/uat_rules.txt", 
    "mapping_file_path": "Qradar_rule/uat_to_prod_mapping.json",
    "environment": "prod"
  },
  
  "feature_engineering": {
    "expected_rules": 1128,
    "window_size_minutes": 30,
    "log_transform": true,
    "normalize_counts": false
  },
  
  "model": {
    "random_forest": {
      "n_estimators": 200,
      "class_weight": "balanced_subsample",
      "max_features": "sqrt",
      "random_state": 42,
      "n_jobs": -1,
      "max_depth": null,
      "min_samples_split": 2,
      "min_samples_leaf": 1
    },
    
    "svm": {
      "C": 1.0,
      "kernel": "rbf",
      "gamma": "scale",
      "probability": true,
      "random_state": 42,
      "class_weight": "balanced"
    },
    
    "logistic_regression": {
      "C": 1.0,
      "penalty": "l2",
      "solver": "liblinear",
      "max_iter": 1000,
      "random_state": 42,
      "class_weight": "balanced"
    },
    
    "gradient_boosting": {
      "n_estimators": 100,
      "learning_rate": 0.1,
      "max_depth": 3,
      "min_samples_split": 2,
      "min_samples_leaf": 1,
      "random_state": 42
    },
    
    "xgboost": {
      "n_estimators": 100,
      "learning_rate": 0.1,
      "max_depth": 6,
      "subsample": 1.0,
      "colsample_bytree": 1.0,
      "random_state": 42,
      "scale_pos_weight": 1
    },
    
    "decision_tree": {
      "criterion": "gini",
      "splitter": "best",
      "max_depth": null,
      "min_samples_split": 2,
      "min_samples_leaf": 1,
      "class_weight": "balanced",
      "random_state": 42
    },
    
    "adaboost": {
      "n_estimators": 50,
      "learning_rate": 1.0,
      "algorithm": "SAMME.R",
      "random_state": 42
    },
    
    "extra_trees": {
      "n_estimators": 100,
      "criterion": "gini",
      "max_depth": null,
      "min_samples_split": 2,
      "min_samples_leaf": 1,
      "max_features": "sqrt",
      "bootstrap": false,
      "class_weight": "balanced",
      "random_state": 42,
      "n_jobs": -1
    },
    
    "naive_bayes": {
      "var_smoothing": 1e-9
    }
  },
  
  "mongodb": {
    "connection_string": "mongodb://localhost:27017/",
    "database_name": "qradar_ml",
    "collection_name": "rule_triggers",
    "query_window_minutes": 30
  },
  
  "logging": {
    "level": "INFO",
    "log_dir": "./running_log",
    "syslog_enabled": true,
    "syslog_address": "192.168.153.123",
    "syslog_port": 514,
    "syslog_header": "AIR-RF"
  },
  
  "paths": {
    "model_dir": "./model",
    "data_dir": "./Training_data",
    "output_dir": "./test_output"
  }
}
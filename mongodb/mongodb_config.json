{
  "mongodb": {
    "host": "localhost",
    "port": 27017,
    "db_name": "qradar_detection",
    "connection_string": "mongodb://localhost:27017/"
  },
  "pipeline": {
    "mode": "detection_only",
    "query_frequency_minutes": 15,
    "window_size": "15min",
    "timezone": "HKT",
    "retention_days": 7
  },
  "collections": {
    "detection_windows": "qradar_sliding_windows",
    "detection_results": "detection_results",
    "aql_events": "aql_events"
  },
  "data_schema": {
    "detection_windows": {
      "_id": "string (window_id from time_utils)",
      "window_start": "datetime",
      "window_end": "datetime",
      "query_time": "datetime",
      "feature_vector": "object (rule_id -> count)",
      "rule_counts": "object (rule_id -> count)",
      "host_triggers": "object (hostname -> {total_triggers, rules, Source IP (majority if multiple)})",
      "total_triggers": "integer",
      "total_rules_triggered": "integer",
      "metadata": {
        "source": "string",
        "data_type": "string",
        "query_id": "string"
      }
    },
    "detection_results": {
      "window_id": "string",
      "timestamp": "datetime",
      "prediction": "integer (0=normal, 1=anomaly)",
      "confidence": "float",
      "model_version": "string",
      "total_events": "integer",
      "unique_rules": "integer"
    },
    "aql_events": {
      "hostname": "string",
      "rule_id": "string",
      "timestamp": "datetime",
      "count": "integer",
      "window_id": "string",
      "metadata": {
        "source": "string",
        "raw_event": "object"
      }
    }
  },
  "rule_mapping": {
    "total_rules": 402,
    "rule_ids": [],
    "source": "Production_baseline",
    "description": "Fixed 402 production rules as baseline for consistent feature vectors across environments",
    "fixed_count": true,
    "uat_mapping": {
      "enabled": true,
      "mapping_file": "shared_utils/uat_to_prod_mapping.csv",
      "description": "UAT-to-Production rule ID mapping for consistent training"
    }
  },
  "time_utils": {
    "timezone": "Asia/Hong_Kong",
    "window_size_minutes": 30,
    "tolerance_seconds": 5,
    "timestamp_format": "%b %d, %Y, %I:%M:%S %p",
    "aql_timestamp_format": "%b %d, %Y, %I:%M:%S %p"
  },
  "detection_mode": {
    "enabled": true,
    "data_source": "AQL_JSON",
    "collections": {
      "windows": "qradar_sliding_windows",
      "results": "detection_results",
      "events": "aql_events"
    },
    "retention_policy": {
      "enabled": true,
      "days": 7,
      "cleanup_collections": ["qradar_sliding_windows", "detection_results", "aql_events"]
    }
  },
  "host_retention": {
    "whitelist_hosts": [],
    "default_retention_days": 7,
    "whitelist_retention_days": 3650
  }
}
